# Porta da aplicação
PORT=3000

# URI de conexão com o MongoDB
MONGO_URI=mongodb://localhost:27017/api-rest

# Secret para geração dos tokens JWT
JWT_SECRET=seu_jwt_secret_super_seguro_aqui

# Tempo de expiração do access token
JWT_EXPIRES_IN=7d

# Secret para o refresh token (deve ser diferente do JWT_SECRET)
JWT_REFRESH_SECRET=seu_jwt_refresh_secret_super_seguro_aqui

# Tempo de expiração do refresh token
JWT_REFRESH_EXPIRES_IN=30d

# Ambiente de execução (development | production | test)
NODE_ENV=development
